# Public API URL — used by browser-side fetch calls
NEXT_PUBLIC_API_URL=http://localhost:8000

# Docker-internal API URL — used by server-side fetch calls (SSR, health check)
# Set this when the backend is reachable at a different URL from the server container
# API_URL_INTERNAL=http://backend:8000

# Canonical origin of the deployed frontend — used for sitemap, robots.txt,
# canonical URLs, and Open Graph tags. Must be the absolute public URL.
NEXT_PUBLIC_SITE_URL=https://phiacta.com
